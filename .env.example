# MS365 → GCP Migration Engine — environment variables
# Copy to .env and fill in values. NEVER commit .env
# In production, all secrets are in GCP Secret Manager — set ENGINE_USE_SECRET_MANAGER=true

# ── Application ───────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO

# ── GCP (non-secret config) ───────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_GCS_BUCKET=your-migration-bucket-name
GCP_REGION=us-central1

# GCP service account key path (dev only — use Workload Identity in production)
# GCP_SERVICE_ACCOUNT_KEY_PATH=./secrets/gcp-sa.json

# ── Microsoft 365 / Graph API ─────────────────────────────────────────────
# Create app registration at https://entra.microsoft.com -> App registrations
# Required Application permissions (Grant admin consent):
#   Mail.Read  Calendars.Read  Contacts.Read  Files.Read.All
#   Sites.Read.All  Team.ReadBasic.All  ChannelMessage.Read.All
#   TeamSettings.Read.All  User.Read.All  Group.Read.All
#   Device.Read.All  Reports.Read.All  Tasks.Read
#   Directory.Read.All  DeviceManagementManagedDevices.Read.All
#
# In dev with ENGINE_USE_SECRET_MANAGER=false, set these directly:
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=

# ── Secret Manager (production) ───────────────────────────────────────────
ENGINE_USE_SECRET_MANAGER=false  # Set to true in production

# In production, these secrets must exist in Secret Manager:
#   ms365-tenant-id
#   ms365-client-id
#   ms365-client-secret
#   gcp-service-account-key (JSON key, if not using Workload Identity)

# ── GCP Emulators (local dev only) ────────────────────────────────────────
# FIRESTORE_EMULATOR_HOST=localhost:8080
# PUBSUB_EMULATOR_HOST=localhost:8085
# STORAGE_EMULATOR_HOST=http://localhost:4443
# GOOGLE_CLOUD_PROJECT=migration-dev-local

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
